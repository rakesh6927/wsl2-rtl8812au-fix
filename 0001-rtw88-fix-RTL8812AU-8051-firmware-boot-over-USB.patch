diff --git a/drivers/net/wireless/realtek/rtw88/mac.c b/drivers/net/wireless/realtek/rtw88/mac.c
index eaa928bab..13ee10551 100644
--- a/drivers/net/wireless/realtek/rtw88/mac.c
+++ b/drivers/net/wireless/realtek/rtw88/mac.c
@@ -437,11 +437,22 @@ static bool check_firmware_size(const u8 *data, u32 size)
 	return true;
 }
 
+static u8 get_wlmcu_ioif_bit(struct rtw_dev *rtwdev)
+{
+	/* 8812A uses BIT3 for MCU IO interface, others use BIT0 */
+	if (rtwdev->chip->id == RTW_CHIP_TYPE_8812A ||
+	    rtwdev->chip->id == RTW_CHIP_TYPE_8814A)
+		return BIT(3);
+	return BIT_WLMCU_IOIF; /* BIT(0) for 8821A, 8822B, etc */
+}
+
 static void wlan_cpu_enable(struct rtw_dev *rtwdev, bool enable)
 {
+	u8 ioif_bit = get_wlmcu_ioif_bit(rtwdev);
+
 	if (enable) {
 		/* cpu io interface enable */
-		rtw_write8_set(rtwdev, REG_RSV_CTRL + 1, BIT_WLMCU_IOIF);
+		rtw_write8_set(rtwdev, REG_RSV_CTRL + 1, ioif_bit);
 
 		/* cpu enable */
 		rtw_write8_set(rtwdev, REG_SYS_FUNC_EN + 1, BIT_FEN_CPUEN);
@@ -450,7 +461,7 @@ static void wlan_cpu_enable(struct rtw_dev *rtwdev, bool enable)
 		rtw_write8_clr(rtwdev, REG_SYS_FUNC_EN + 1, BIT_FEN_CPUEN);
 
 		/* cpu disable */
-		rtw_write8_clr(rtwdev, REG_RSV_CTRL + 1, BIT_WLMCU_IOIF);
+		rtw_write8_clr(rtwdev, REG_RSV_CTRL + 1, ioif_bit);
 	}
 }
 
@@ -837,6 +848,19 @@ static void en_download_firmware_legacy(struct rtw_dev *rtwdev, bool en)
 	int try;
 
 	if (en) {
+		/* Reset 8051 if firmware already loaded (matches aircrack-ng sequence) */
+		if (rtw_read8(rtwdev, REG_MCUFW_CTRL) & BIT_RAM_DL_SEL) {
+			wlan_cpu_enable(rtwdev, false);
+			/* Clear BIT1 in REG_RSV_CTRL for MCU IO wrapper reset */
+			if (rtwdev->chip->id == RTW_CHIP_TYPE_8812A ||
+			    rtwdev->chip->id == RTW_CHIP_TYPE_8814A)
+				rtw_write8_clr(rtwdev, REG_RSV_CTRL, BIT(1));
+			wlan_cpu_enable(rtwdev, true);
+		}
+
+		/* Reset MCU ready status (REG_MCUFWDL = 0x00 in aircrack-ng) */
+		rtw_write8(rtwdev, REG_MCUFW_CTRL, 0x00);
+
 		wlan_cpu_enable(rtwdev, false);
 		wlan_cpu_enable(rtwdev, true);
 
@@ -934,14 +958,16 @@ static int download_firmware_validate_legacy(struct rtw_dev *rtwdev)
 	wlan_cpu_enable(rtwdev, false);
 	wlan_cpu_enable(rtwdev, true);
 
-	for (try = 0; try < 10; try++) {
+	for (try = 0; try < 50; try++) {
 		val32 = rtw_read32(rtwdev, REG_MCUFW_CTRL);
-		if ((val32 & FW_READY_LEGACY) == FW_READY_LEGACY)
+		if ((val32 & FW_READY_LEGACY) == FW_READY_LEGACY) {
+			rtw_info(rtwdev, "firmware validated after %d tries\n", try + 1);
 			return 0;
-		msleep(20);
+		}
+		msleep(50);
 	}
 
-	rtw_err(rtwdev, "failed to validate firmware\n");
+	rtw_err(rtwdev, "failed to validate firmware, last val32=0x%08x\n", val32);
 	return -EINVAL;
 }
 
